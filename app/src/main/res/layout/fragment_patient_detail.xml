<?xml version="1.0" encoding="utf-8"?>
<ScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Overview Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/surface_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="35dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1.5dp">
                    <ImageView
                        android:id="@+id/detail_patient_photo"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:scaleType="centerCrop"
                        android:contentDescription="Patient avatar" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/detail_patient_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="John Doe"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_patient_mrn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="MRN-2026-0001"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Dynamic Barcode Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/surface_variant"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLINICAL PATIENT BARCODE"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <ImageView
                    android:id="@+id/detail_patient_barcode"
                    android:layout_width="260dp"
                    android:layout_height="64dp"
                    android:contentDescription="Patient MRN Barcode" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Personal Details Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/surface_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PATIENT DEMOGRAPHICS"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="National ID Number"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_patient_nid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NID-7738221"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gender / Date of Birth"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_patient_gender_dob"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Male / 1985-04-12"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Blood Type"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_patient_blood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A+"
                    android:textColor="@color/primary_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Contact Phone / Email"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_patient_contact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+1 (555) 987-1111 | john.doe@email.com"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Residential Address"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_patient_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="123 Maple St, Seattle"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Emergency Contact"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_patient_emergency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jane Doe (+15559872)"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Insurance Information"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_patient_insurance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sigma Health Insurance"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Medical History Summary"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_patient_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No chronic conditions. Mild pollen allergies."
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Shortcuts / Quick Operations Row -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_medical_record"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="12dp"
            android:text="CREATE MEDICAL RECORD"
            app:icon="@android:drawable/ic_menu_add" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_patient"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="DELETE"
                android:textColor="@color/danger"
                app:iconTint="@color/danger"
                app:icon="@android:drawable/ic_menu_delete" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_patient"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="EDIT"
                app:icon="@android:drawable/ic_menu_edit" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
