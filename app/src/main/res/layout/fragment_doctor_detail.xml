<?xml version="1.0" encoding="utf-8"?>
<ScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Profile Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/surface_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="45dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="2dp">
                    <ImageView
                        android:id="@+id/detail_doc_photo"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:scaleType="centerCrop"
                        android:contentDescription="Doctor Photo" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/detail_doc_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Dr. Sarah Jenkins"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_doc_specialty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cardiology Specialist"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_doc_status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/badge_success"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:text="ACTIVE"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Information details Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/surface_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROFESSIONAL DETAILS"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Medical License ID"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_doc_license"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LIC-12345"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gender"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_doc_gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Female"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Contact Phone"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_doc_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+1 (555) 019-2111"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_doc_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="sarah.jenkins@sigma.com"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Practice Schedule"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/detail_doc_schedule"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mon-Wed: 09:00 - 15:00"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- QR Code Verification Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/surface_variant"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOSPITAL ID QR CODE"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />
                <ImageView
                    android:id="@+id/detail_doc_qr"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:contentDescription="Doctor QR ID" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Control Row -->
        <LinearLayout
            android:id="@+id/layout_admin_doctor_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_doctor"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="DELETE"
                android:textColor="@color/danger"
                app:iconTint="@color/danger"
                app:icon="@android:drawable/ic_menu_delete" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_doctor"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="EDIT PROFILE"
                app:icon="@android:drawable/ic_menu_edit" />

        </LinearLayout>

        <!-- Patient Booking Action -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_book_doctor"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="24dp"
            android:text="BOOK APPOINTMENT"
            android:visibility="gone"
            app:icon="@android:drawable/ic_menu_my_calendar" />

    </LinearLayout>
</ScrollView>
